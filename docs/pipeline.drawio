<mxfile host="app.diagrams.net">
  <diagram name="drought-pipeline" id="drought-pipeline">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Drought Classifier - Baseline Pipeline (status as of 2026-06-17)" style="text;html=1;fontSize=18;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="700" height="30" as="geometry" />
        </mxCell>

        <!-- raw inputs -->
        <mxCell id="usdm" value="USDM weekly labels&#10;(drought.gov, Kerr Co.)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="170" height="50" as="geometry" />
        </mxCell>
        <mxCell id="noaa" value="NOAA daily&#10;(3 files + 2005-09 re-pull)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="210" width="170" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ndvi" value="MODIS NDVI&#10;16-day (to 2024)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="310" width="170" height="50" as="geometry" />
        </mxCell>

        <!-- preprocessing scripts -->
        <mxCell id="relabel" value="relabel_usdm_labels.py&#10;None-&gt;no_drought, reindex 0-5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="260" y="110" width="190" height="50" as="geometry" />
        </mxCell>
        <mxCell id="combine" value="combine_noaa.py&#10;concat + dedup + UNIT FIX" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="260" y="210" width="190" height="50" as="geometry" />
        </mxCell>

        <!-- intermediate csvs -->
        <mxCell id="usdmcsv" value="USDM_labels.csv" style="shape=note;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="500" y="110" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="noaacsv" value="NOAA_combined_2000-2026.csv" style="shape=note;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="500" y="210" width="150" height="50" as="geometry" />
        </mxCell>

        <!-- preparing_data -->
        <mxCell id="prep" value="preparing_data.py&#10;&#10;- resample NOAA/NDVI -&gt; weekly&#10;- merge onto USDM grid&#10;- window (W=4, L=4), flatten&#10;- one-hot (6 classes)&#10;- chronological split + scale" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="700" y="120" width="220" height="150" as="geometry" />
        </mxCell>

        <!-- model -->
        <mxCell id="train" value="train_and_visualize.py&#10;&#10;MLP 16 -&gt; 64 -&gt; 32 -&gt; 6 softmax&#10;categorical_crossentropy&#10;EarlyStopping" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="970" y="135" width="210" height="120" as="geometry" />
        </mxCell>

        <!-- outputs -->
        <mxCell id="metrics" value="metrics.txt&#10;acc 0.39 / macroF1 0.29" style="shape=note;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1230" y="80" width="150" height="45" as="geometry" />
        </mxCell>
        <mxCell id="cm" value="confusion_matrix.png" style="shape=note;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1230" y="140" width="150" height="45" as="geometry" />
        </mxCell>
        <mxCell id="loss" value="loss_curve.png" style="shape=note;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1230" y="200" width="150" height="45" as="geometry" />
        </mxCell>
        <mxCell id="preds" value="test_predictions.csv" style="shape=note;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1230" y="260" width="150" height="45" as="geometry" />
        </mxCell>

        <!-- edges -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="usdm" target="relabel"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="noaa" target="combine"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="relabel" target="usdmcsv"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="combine" target="noaacsv"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="usdmcsv" target="prep"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="noaacsv" target="prep"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="ndvi" target="prep"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="prep" target="train"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="train" target="metrics"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="train" target="cm"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="train" target="loss"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="train" target="preds"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- not-yet-integrated cluster -->
        <mxCell id="sep" value="Not yet integrated into the working pipeline (the fuller config-driven path)" style="text;html=1;fontSize=13;fontStyle=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="440" width="600" height="20" as="geometry" />
        </mxCell>
        <mxCell id="driver" value="training_driver.py&#10;config-driven full driver (partially adapted, NOT running)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="parser" value="parser.py + configs/&#10;argparse @config (exists, not wired)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="40" y="545" width="240" height="55" as="geometry" />
        </mxCell>
        <mxCell id="tune" value="tuning_driver.py (stub)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="310" y="470" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="infer" value="inference_driver.py (stub)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="310" y="525" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="vizdr" value="visualization_driver.py (stub)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="310" y="580" width="200" height="40" as="geometry" />
        </mxCell>

        <!-- legend -->
        <mxCell id="leg" value="Legend" style="text;html=1;fontSize=13;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="700" y="440" width="120" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg_g" value="coded + tested working" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="700" y="465" width="220" height="35" as="geometry" />
        </mxCell>
        <mxCell id="leg_y" value="coded, partial / not running yet" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="700" y="510" width="220" height="35" as="geometry" />
        </mxCell>
        <mxCell id="leg_x" value="stub / not started" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="700" y="555" width="220" height="35" as="geometry" />
        </mxCell>
        <mxCell id="leg_b" value="raw data input" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="700" y="600" width="220" height="35" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
